{
  "name": "donassistec-backend",
  "version": "1.0.0",
  "description": "Backend API para DonAssistec",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "migrate:pre-pedidos": "tsx scripts/run-migration-23.ts",
    "migrate:pre-pedidos-contact": "tsx scripts/run-migration-24.ts",
    "migrate:pre-pedidos-need-by": "tsx scripts/run-migration-25.ts",
    "migrate:pre-pedidos-numero": "tsx scripts/run-migration-26.ts",
    "migrate:orders-numero": "tsx scripts/run-migration-27.ts",
    "migrate:order-items": "tsx scripts/run-migration-28.ts",
    "migrate:admin-team": "tsx scripts/run-migration-29.ts",
    "migrate:retailer-price-tables": "tsx scripts/run-migration-30.ts",
    "migrate:retailer-price-tables-utf8mb4": "tsx scripts/run-migration-31.ts",
    "migrate:retailer-price-tables-display": "tsx scripts/run-migration-32.ts"
  },
  "keywords": [
    "donassistec",
    "api",
    "mysql"
  ],
  "author": "DonAssistec",
  "license": "MIT",
  "dependencies": {
    "@types/multer": "^2.0.0",
    "@types/socket.io": "^3.0.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.6.5",
    "socket.io": "^4.8.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
