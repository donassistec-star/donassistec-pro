# Exemplo de bloco HTTPS para donassistec.com.br
# Adicione este server {} em /etc/nginx/sites-available/donassistec
# DEPOIS de ter os certificados (certbot).
#
# 1) Obter certificados:
#    sudo certbot certonly --webroot -w /var/www/html -d donassistec.com.br -d www.donassistec.com.br
#    ou: sudo certbot --nginx -d donassistec.com.br -d www.donassistec.com.br
#
# 2) Ajustar os caminhos ssl_certificate e ssl_certificate_key se o certbot usar outro path.
#
# 3) sudo nginx -t && sudo systemctl reload nginx
#
# 4) Firewall: sudo ufw allow 443 && sudo ufw reload

server {
    listen 443 ssl;
    server_name 177.67.32.204 donassistec.com.br www.donassistec.com.br;

    ssl_certificate     /etc/letsencrypt/live/donassistec.com.br/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/donassistec.com.br/privkey.pem;

    client_max_body_size 10M;

    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain text/css text/xml text/javascript application/javascript application/json;

    location /api {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /uploads {
        proxy_pass http://127.0.0.1:3001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /health {
        proxy_pass http://127.0.0.1:3001;
        proxy_set_header Host $host;
        access_log off;
    }

    # Frontend (SPA) + fallback para rotas como /apk
    location / {
        proxy_pass http://127.0.0.1:8200;
        proxy_http_version 1.1;
        proxy_set_header Host 127.0.0.1;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_intercept_errors on;
        error_page 404 = @spa;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_cache_bypass $http_upgrade;
    }

    location @spa {
        proxy_pass http://127.0.0.1:8200;
        proxy_http_version 1.1;
        proxy_set_header Host 127.0.0.1;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# Opcional: redirecionar HTTP → HTTPS (ative depois que o SSL estiver OK)
