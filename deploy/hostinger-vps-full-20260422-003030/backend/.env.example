# Porta do servidor
PORT=3001

# Configurações do Banco de Dados
DB_HOST=localhost
DB_PORT=3306
DB_USER=donassistec_user
DB_PASSWORD=donassistec_password
DB_NAME=donassistec_db

# JWT Secret (GERE UM SECRET ÚNICO E SEGURO!)
JWT_SECRET=seu_jwt_secret_super_seguro_aqui
JWT_EXPIRES_IN=7d
ENABLE_ADMIN_BOOTSTRAP=false

# CORS - origem do frontend (produção: http://donassistec.com.br ou https://donassistec.com.br)
CORS_ORIGIN=http://localhost:8200

# Socket.IO
SOCKET_IO_PORT=3001

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
