# URL da API (opcional - o sistema detecta localhost e donassistec.com.br)
# Descomente para override. Produção com domínio donassistec.com.br já é detectado.
# VITE_API_URL=http://localhost:3001/api
# VITE_API_URL=https://donassistec.com.br/api

# --- Produção: domínio http://donassistec.com.br ---
# O frontend detecta donassistec.com.br e www.donassistec.com.br e usa /api no mesmo host.
# No backend (.env): CORS_ORIGIN=https://donassistec.com.br (ou http conforme seu servidor)

# --- Desenvolvimento: acessar o dev server por IP (ex: 177.67.32.204:8200) ---
# HMR (Hot Module Replacement): defina o host para o WebSocket funcionar
# VITE_HMR_HOST=177.67.32.204
# VITE_HMR_PORT=8200

# Em Docker/VM/remoto, se módulos .tsx falharem com ERR_CONNECTION_RESET ou o watching não funcionar:
# VITE_USE_POLLING=1
